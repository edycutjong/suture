# --- Fivetran ---
# Get API key/secret from: https://fivetran.com/account/api
FIVETRAN_API_KEY=
FIVETRAN_API_SECRET=

# --- Google Cloud / Gemini ---
# Get from: https://console.cloud.google.com/apis/credentials
GEMINI_API_KEY=

# --- Supabase ---
# Get from: https://supabase.com/dashboard → Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Arize Phoenix ---
# Get from: https://app.phoenix.arize.com → Settings → API Keys
PHOENIX_API_KEY=
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com

# Agent mode: "mock" for demo, "live" for real Fivetran
AGENT_MODE=mock
