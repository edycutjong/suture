# ============================================
# Suture — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.

# --- Fivetran ---
# Get API key/secret from: https://fivetran.com/account/api
FIVETRAN_API_KEY=your_fivetran_api_key
FIVETRAN_API_SECRET=your_fivetran_api_secret

# --- Google Cloud / Gemini ---
# Get from: https://console.cloud.google.com/apis/credentials
GEMINI_API_KEY=your_gemini_api_key
GOOGLE_CLOUD_PROJECT=your_gcp_project_id

# --- Supabase ---
# Get from: https://supabase.com/dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- Arize Phoenix ---
# Get from: https://app.phoenix.arize.com → Settings → API Keys
PHOENIX_API_KEY=your_phoenix_api_key
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com

# --- Agent Config ---
AGENT_MODE=mock  # 'mock' for demos, 'live' for real Fivetran API
AGENT_PORT=8000

# --- Dashboard ---
NEXT_PUBLIC_AGENT_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
