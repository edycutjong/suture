# ============================================
# Suture — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.

# --- Fivetran ---
# Create a System Key: https://fivetran.com/docs/rest-api/getting-started/system-keys
# Dashboard → Account Settings → General → System Keys → Add System Key
# Required access rules JSON:
#   [
#     { "resource_type": "CONNECTOR", "access_level": "MANAGE" },
#     { "resource_type": "WEBHOOK", "access_level": "MANAGE" }
#   ]
FIVETRAN_API_KEY=your_fivetran_api_key
FIVETRAN_API_SECRET=your_fivetran_api_secret

# --- Google Cloud / Gemini ---
# Get from: https://console.cloud.google.com/apis/credentials
GEMINI_API_KEY=your_gemini_api_key
GOOGLE_CLOUD_PROJECT=your_gcp_project_id

# --- Supabase ---
# Get from: https://supabase.com/dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- Arize Phoenix (OPTIONAL) ---
# Observability tracing. Agent works without it (traces stored in-memory).
# Get from: https://app.phoenix.arize.com → Settings → Keys → System API Keys → Create
# Generate a key value: openssl rand -base64 32
PHOENIX_API_KEY=
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com

# --- Agent Config ---
AGENT_MODE=mock  # 'mock' for demos, 'live' for real Fivetran API
AGENT_PORT=8000

# --- Dashboard ---
NEXT_PUBLIC_AGENT_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
